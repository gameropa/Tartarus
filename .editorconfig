# TARTARUS Engine - EditorConfig Configuration
# Matches the hybrid C/C++ 8-spaces style setup

root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{c,h,cpp,hpp,cc,hh,inl}]
indent_style = tab
indent_size = 8
tab_width = 8
max_line_length = 80


[*.{json,xml,yaml,yml}]
indent_style = space
indent_size = 2

[Makefile,*.mk]
indent_style = tab
tab_width = 8
